# App
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=
DB_PASSWORD=
# Optional: comma-separated fallback ports to try if DB_PORT fails
DB_FALLBACK_PORTS=3307
# Optional: retry attempts per port (default 2)
DB_CONNECT_RETRIES=2
# Optional: delay between retries in milliseconds (default 1500)
DB_CONNECT_RETRY_DELAY_MS=1500
# Optional: keep retrying DB in background after server starts (default 10000)
DB_BACKGROUND_RETRY_MS=10000

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10
